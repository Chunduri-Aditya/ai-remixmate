{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI RemixMate Manifest",
  "description": "Manifest file for Python → Logic Pro bridge communication",
  "type": "object",
  "required": [
    "version",
    "project_path",
    "session",
    "tempo_key",
    "mix_params",
    "import",
    "bounce",
    "smart_tempo"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "project_path": {
      "type": "string",
      "description": "Path to Logic Pro template project (.logicx file)"
    },
    "session": {
      "type": "object",
      "required": ["id", "out_dir"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique session identifier"
        },
        "out_dir": {
          "type": "string",
          "description": "Output directory for this session"
        }
      }
    },
    "tempo_key": {
      "type": "object",
      "required": ["project_bpm", "base_track", "vocal_track"],
      "properties": {
        "project_bpm": {
          "type": "number",
          "minimum": 60,
          "maximum": 200,
          "description": "Project tempo in BPM"
        },
        "project_key": {
          "type": "string",
          "pattern": "^[0-9]{1,2}[AB]$",
          "description": "Camelot wheel key notation (e.g., 8A, 5B)"
        },
        "base_track": {
          "type": "object",
          "required": ["bpm", "key", "path"],
          "properties": {
            "bpm": {"type": "number"},
            "key": {"type": "string"},
            "path": {"type": "string"}
          }
        },
        "vocal_track": {
          "type": "object",
          "required": ["bpm", "key", "path"],
          "properties": {
            "bpm": {"type": "number"},
            "key": {"type": "string"},
            "path": {"type": "string"}
          }
        }
      }
    },
    "mix_params": {
      "type": "object",
      "required": [
        "vocal_gain_db",
        "inst_gain_db",
        "sidechain_amount",
        "hp_filter_hz",
        "reverb_send"
      ],
      "properties": {
        "vocal_gain_db": {
          "type": "number",
          "minimum": -24,
          "maximum": 12,
          "description": "Vocal track gain in dB"
        },
        "inst_gain_db": {
          "type": "number",
          "minimum": -24,
          "maximum": 12,
          "description": "Instrumental track gain in dB"
        },
        "sidechain_amount": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Sidechain compression amount (0-1)"
        },
        "hp_filter_hz": {
          "type": "number",
          "minimum": 20,
          "maximum": 500,
          "description": "High-pass filter frequency in Hz"
        },
        "reverb_send": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Reverb send amount (0-1)"
        }
      }
    },
    "import": {
      "type": "object",
      "required": ["tracks"],
      "properties": {
        "tracks": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "required": ["logic_track_name", "audio_path"],
            "properties": {
              "logic_track_name": {
                "type": "string",
                "enum": ["AI_INSTRUMENTAL", "AI_VOCALS"]
              },
              "audio_path": {
                "type": "string",
                "description": "Path to audio file"
              }
            }
          }
        }
      }
    },
    "bounce": {
      "type": "object",
      "required": ["filename", "path", "sample_rate", "bit_depth", "normalize"],
      "properties": {
        "filename": {
          "type": "string",
          "description": "Bounce filename"
        },
        "path": {
          "type": "string",
          "description": "Full path to bounce file"
        },
        "sample_rate": {
          "type": "integer",
          "enum": [44100, 48000, 88200, 96000]
        },
        "bit_depth": {
          "type": "integer",
          "enum": [16, 24, 32]
        },
        "normalize": {
          "type": "boolean",
          "description": "Whether to normalize the bounce"
        }
      }
    },
    "smart_tempo": {
      "type": "object",
      "required": ["mode", "analyze_on_import"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["ADAPT", "KEEP", "AUTO"],
          "description": "Smart Tempo mode"
        },
        "analyze_on_import": {
          "type": "boolean",
          "description": "Whether to analyze tempo on import"
        }
      }
    }
  }
}
