{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-remixmate.local/schemas/trainingEvent.schema.json",
  "title": "TrainingEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "featureName", "inputVector", "targetVector", "source", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable event identifier."
    },
    "featureName": {
      "type": "string",
      "description": "Name of the adaptive feature model that should learn from this event."
    },
    "inputVector": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "type": "number",
        "minimum": -1,
        "maximum": 1
      },
      "description": "Bounded numeric model input vector."
    },
    "targetVector": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "description": "Bounded target vector. Scores and risks are represented from 0 to 1."
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "default": 1,
      "description": "Optional event weighting. Higher values make one event count more, within a bounded range."
    },
    "source": {
      "type": "string",
      "enum": ["user_feedback", "manual_correction", "render_review", "test_fixture", "imported_label"],
      "description": "Where the supervision came from."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "description": "Optional non-training metadata such as track IDs or UI location."
    }
  }
}
